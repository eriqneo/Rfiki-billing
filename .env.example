# Rafiki Business Manager Environment Configuration

# Authentication Mode ('local' or 'pocketbase')
VITE_AUTH_MODE=local

# PocketBase URL (when VITE_AUTH_MODE=pocketbase)
# VITE_POCKETBASE_URL=https://rafiki.pockethost.io

# Google Calendar OAuth (for Sync Service)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_API_KEY=your-google-api-key
